generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String?
  startTime DateTime
  endTime   DateTime
  timezone  String
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model AdminSettings {
  id           String  @id @default("singleton")
  passwordHash String?
}

model AvailabilityDay {
  id        String  @id @default(cuid())
  dayOfWeek Int     @unique
  enabled   Boolean @default(true)
  startHour Int     @default(9)
  startMin  Int     @default(0)
  endHour   Int     @default(17)
  endMin    Int     @default(0)
}

model BlockedDate {
  id   String  @id @default(cuid())
  date String
  note String?
}

model SiteContent {
  key   String @id
  value String
}
